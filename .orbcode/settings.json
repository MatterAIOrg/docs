{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "ask_followup_question",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$LINEAR_AGENT_ASK_HOOK\" \"$JOB_ID\" \"$LINEAR_AGENT_IPC_DIR\"",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$LINEAR_AGENT_ERROR_HOOK\" \"$JOB_ID\" \"$LINEAR_AGENT_IPC_DIR\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$LINEAR_AGENT_ERROR_HOOK\" \"$JOB_ID\" \"$LINEAR_AGENT_IPC_DIR\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$LINEAR_AGENT_ERROR_HOOK\" \"$JOB_ID\" \"$LINEAR_AGENT_IPC_DIR\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$LINEAR_AGENT_ASK_HOOK\" \"$JOB_ID\" \"$LINEAR_AGENT_IPC_DIR\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
